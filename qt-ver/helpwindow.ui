           <family>Avenir</family>
           <pointsize>14</pointsize>
          </font>
         </property>
         <property name="text">
          <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; color:#ffffff;&quot;&gt;• Click the &lt;/span&gt;&lt;span style=&quot; font-weight:700; color:#ffffff;&quot;&gt;&amp;quot;+&amp;quot;&lt;/span&gt;&lt;span style=&quot; color:#ffffff;&quot;&gt; button to &lt;/span&gt;&lt;span style=&quot; font-weight:700; color:#ffffff;&quot;&gt;create&lt;/span&gt;&lt;span style=&quot; color:#ffffff;&quot;&gt; a new task.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; color:#ffffff;&quot;&gt;• Enter a title for your task.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; color:#ffffff;&quot;&gt;• Add a description if needed (this step is completely optional).&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; color:#ffffff;&quot;&gt;• Set a deadline for your task:&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; color:#ffffff;&quot;&gt;- If the selected date is in the &lt;/span&gt;&lt;span style=&quot; font-weight:700; color:#ffffff;&quot;&gt;future&lt;/span&gt;&lt;span style=&quot; color:#ffffff;&quot;&gt;, it will be displayed normally.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; color:#ffffff;&quot;&gt;- If the selected date is in the &lt;/span&gt;&lt;span style=&quot; font-weight:700; color:#ffffff;&quot;&gt;past&lt;/span&gt;&lt;span style=&quot; color:#ffffff;&quot;&gt;, the deadline will automatically be set to &lt;/span&gt;&lt;span style=&quot; font-weight:700; color:#ffffff;&quot;&gt;ASAP&lt;/span&gt;&lt;span style=&quot; color:#ffffff;&quot;&gt; (As Soon As Possible).&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; color:#ffffff;&quot;&gt;• Double-click the task title, description, or deadline to &lt;/span&gt;&lt;span style=&quot; font-weight:700; color:#ffffff;&quot;&gt;edit&lt;/span&gt;&lt;span style=&quot; color:#ffffff;&quot;&gt; it.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; color:#ffffff;&quot;&gt;• Mark a task as &lt;/span&gt;&lt;span style=&quot; font-weight:700; color:#ffffff;&quot;&gt;completed&lt;/span&gt;&lt;span style=&quot; color:#ffffff;&quot;&gt; by toggling the checkbox on the left side of the task widget.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; color:#ffffff;&quot;&gt;• &lt;/span&gt;&lt;span style=&quot; font-weight:700; color:#ffffff;&quot;&gt;Delete&lt;/span&gt;&lt;span style=&quot; color:#ffffff;&quot;&gt; a task by clicking the trash bin icon in the top-right corner of the task widget.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-family:'-webkit-standard'; font-size:medium; color:#ffffff;&quot;&gt;• If you are unsure what a button or text element does, &lt;/span&gt;&lt;span style=&quot; font-family:'-webkit-standard'; font-size:medium; font-weight:700; color:#ffffff;&quot;&gt;hover&lt;/span&gt;&lt;span style=&quot; font-family:'-webkit-standard'; font-size:medium; color:#ffffff;&quot;&gt; your mouse over it to see a &lt;/span&gt;&lt;span style=&quot; font-family:'-webkit-standard'; font-size:medium; font-weight:700; color:#ffffff;&quot;&gt;helpful tooltip&lt;/span&gt;&lt;span style=&quot; font-family:'-webkit-standard'; font-size:medium; color:#ffffff;&quot;&gt;.&lt;/span&gt;&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
         </property>
